# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Python
backend/venv/
backend/venv_test/
**/__pycache__/
*.pyc

# Supabase CLI cache
supabase/.temp/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
# /ios  # committed for Xcode Cloud
/android
.env

# Web dashboard
web/.next/
web/node_modules/

# Play Store AAB bundles
*.aab
assets/playstore-aabs/

# Screenshots & debug images
*.png
!assets/**/*.png
!src/**/*.png
!web/public/**/*.png
!ios/**/Images.xcassets/**/*.png
!android/**/res/**/*.png

# Test results
web/test-results/

# Expo
.expo/

# Claude (local-only by default)
.claude/*
# ...except the data-leak audit agent (committed for cross-repo install)
!.claude/agents/
.claude/agents/*
!.claude/agents/data-leak-auditor.md

# Allow Xcode Cloud ci_scripts (inside gitignored ios/)
!ios/ci_scripts/
!ios/ci_scripts/**
