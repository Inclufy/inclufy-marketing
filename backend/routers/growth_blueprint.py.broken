# backend/routers/growth_blueprint.py
# UPDATED VERSION - With Real Data Integration
from fastapi import APIRouter, Depends, HTTPException, status
from typing import Optional
from datetime import datetime
from supabase import Client
from pydantic import BaseModel
import os
import asyncio

from dependencies import get_current_user, get_supabase_client

router = APIRouter(prefix="/api/growth-blueprint", tags=["Growth Blueprint"])

class BlueprintScanInput(BaseModel):
    company_name: str
    website_url: Optional[str] = None
    industry: Optional[str] = None
    mission_statement: Optional[str] = None
    current_revenue: Optional[float] = None
    target_revenue_12m: Optional[float] = None
    marketing_budget: Optional[float] = None
    team_size: Optional[int] = None

@router.get("/")
def list_blueprints(
    current_user: dict = Depends(get_current_user),
    db: Client = Depends(get_supabase_client)
):
    try:
        result = db.table("growth_blueprints")\
            .select("*")\
            .eq("user_id", current_user["id"])\
            .order("created_at", desc=True)\
            .execute()
        return result.data
    except Exception as e:
        print(f"Error: {e}")
        return []

@router.post("/", status_code=status.HTTP_201_CREATED)
def create_blueprint(
    scan_input: BlueprintScanInput,
    current_user: dict = Depends(get_current_user),
    db: Client = Depends(get_supabase_client)
):
    print(f"🔵 Received request to create blueprint: {scan_input.company_name}")
    
    try:
        blueprint_data = {
            "user_id": current_user["id"],
            "company_name": scan_input.company_name,
            "website_url": scan_input.website_url,
            "industry": scan_input.industry,
            "status": "scanning",
            "scan_progress": 10,
            "scan_started_at": datetime.utcnow().isoformat(),
        }
        
        print(f"🔵 Inserting into database: {blueprint_data}")
        
        result = db.table("growth_blueprints").insert(blueprint_data).execute()
        blueprint = result.data[0]
        
        print(f"✅ Blueprint created: {blueprint['id']}")
        
        # Check if real data is enabled
        use_real_data = os.getenv("ENABLE_REAL_DATA", "false").lower() == "true"
        
        # Start background analysis
        import threading
        
        if use_real_data:
            print("🚀 Using REAL DATA analysis")
            threading.Thread(
                target=complete_scan_with_real_data,
                args=(blueprint, scan_input, db),
                daemon=True
            ).start()
        else:
            print("🎭 Using MOCK DATA (set ENABLE_REAL_DATA=true for real analysis)")
            threading.Thread(
                target=complete_scan_with_mock_data,
                args=(blueprint, scan_input, db),
                daemon=True
            ).start()
        
        return blueprint
        
    except Exception as e:
        print(f"❌ Error creating blueprint: {str(e)}")
        import traceback
        traceback.print_exc()
        raise HTTPException(status_code=500, detail=str(e))


def complete_scan_with_real_data(blueprint: dict, scan_input: BlueprintScanInput, db: Client):
    """Complete scan using REAL DATA from web scraping and APIs"""
    
    try:
        from services.real_data_analyzer import analyze_company_with_real_data
        
        loop = asyncio.new_event_loop()
        asyncio.set_event_loop(loop)
        
        print(f"🔬 Starting REAL DATA collection for: {scan_input.company_name}")
        
        db.table("growth_blueprints").update({
            "scan_progress": 25,
            "status": "analyzing_website"
        }).eq("id", blueprint['id']).execute()
        
        real_data = loop.run_until_complete(
            analyze_company_with_real_data(
                company_name=scan_input.company_name,
                website_url=scan_input.website_url or "",
                industry=scan_input.industry
            )
        )
        
        print(f"✅ Real data collected: Overall score {real_data['overall_score']}/100")
        
        db.table("growth_blueprints").update({
            "scan_progress": 50,
            "status": "analyzing_content"
        }).eq("id", blueprint['id']).execute()
        
        website_analysis = real_data['website_analysis'].get('ai_analysis') or {}
        scores = real_data['scores']
        
        status_quo_data = {
            "blueprint_id": blueprint['id'],
            "company_name": real_data['company_name'],
            "industry": real_data['industry'],
            "website_url": real_data['website_url'],
            "website_score": scores.get('website', 50),
            "seo_score": scores.get('seo', 50),
            "content_score": scores.get('content', 50),
            "social_score": scores.get('social', 50),
            "brand_consistency_score": int((scores.get('website', 50) + scores.get('content', 50)) / 2),
            "market_position": 47,
            "market_position_percentile": 53,
            "strengths": website_analysis.get('strengths', [
                f"Website kwaliteit score: {scores.get('website', 50)}/100",
                f"Content kwaliteit: {scores.get('content', 50)}/100",
                f"Social media aanwezigheid: {real_data['social_presence']['total_platforms']} platforms"
            ]),
            "weaknesses": website_analysis.get('weaknesses', [
                "SEO optimalisatie kansen geïdentificeerd",
                "Content strategie kan worden verbeterd"
            ]),
            "current_limitations": [
                "Online zichtbaarheid optimalisatie nodig" if scores.get('seo', 50) < 60 else "Goede online zichtbaarheid",
                "Content marketing strategie ontwikkelen" if scores.get('content', 50) < 70 else "Sterke content aanwezig",
                "Social media strategie versterken" if scores.get('social', 50) < 70 else "Goede social media presence"
            ],
            "growth_accelerators": [
                "SEO optimalisatie programma" if scores.get('seo', 50) < 70 else "SEO verder optimaliseren",
                "Content marketing campagne",
                "Social media advertising",
                website_analysis.get('key_services', ["Marketing automation"])[0] if website_analysis.get('key_services') else "Marketing automation"
            ]
        }
        
        db.table("blueprint_status_quo").insert(status_quo_data).execute()
        
        if real_data['news_articles']:
            media_mentions = [
                {
                    "source": article['source'],
                    "title": article['title'],
                    "date": article.get('published_at', '')[:10] if article.get('published_at') else '',
                    "url": article.get('url', ''),
                    "sentiment": article.get('sentiment', 'neutral')
                }
                for article in real_data['news_articles'][:5]
            ]
            
            db.table("blueprint_status_quo").update({
                "media_mentions": media_mentions,
                "media_presence_score": scores.get('media', 0)
            }).eq("blueprint_id", blueprint['id']).execute()
        
        db.table("growth_blueprints").update({
            "scan_progress": 70,
            "status": "generating_recommendations"
        }).eq("id", blueprint['id']).execute()
        
        vision_data = {
            "blueprint_id": blueprint['id'],
            "stated_mission": scan_input.mission_statement or website_analysis.get('value_proposition', 'Missie niet opgegeven'),
            "extracted_vision": website_analysis.get('value_proposition', 'Visie geëxtraheerd uit website analyse'),
            "gap_analysis": [
                {"area": "Online Presence", "current": f"{scores.get('website', 50)}/100", "target": "85/100", "gap_percentage": max(0, 85 - scores.get('website', 50))},
                {"area": "SEO Performance", "current": f"{scores.get('seo', 50)}/100", "target": "80/100", "gap_percentage": max(0, 80 - scores.get('seo', 50))},
                {"area": "Content Quality", "current": f"{scores.get('content', 50)}/100", "target": "85/100", "gap_percentage": max(0, 85 - scores.get('content', 50))},
                {"area": "Social Media", "current": f"{scores.get('social', 50)}/100", "target": "80/100", "gap_percentage": max(0, 80 - scores.get('social', 50))}
            ],
            "ambition_risk_score": 65,
            "reality_alignment_score": min(real_data['overall_score'] + 10, 100)
        }
        db.table("blueprint_vision").insert(vision_data).execute()
        
        recommendations = generate_smart_recommendations(scores, website_analysis)
        
        for rec in recommendations:
            rec['blueprint_id'] = blueprint['id']
            db.table("blueprint_recommendations").insert(rec).execute()
        
        opportunities = [
            {
                "blueprint_id": blueprint['id'],
                "type": "SEO Opportunity" if scores.get('seo', 50) < 60 else "Market Position",
                "title": "SEO Optimalisatie Potentieel" if scores.get('seo', 50) < 60 else "Marktpositie Versterken",
                "description": f"Met huidige SEO score van {scores.get('seo', 50)}/100 is er groot verbeterpotentieel" if scores.get('seo', 50) < 60 else "Sterke basis om marktleider te worden",
                "potential_value": "20-40% meer organisch verkeer" if scores.get('seo', 50) < 60 else "Marktleiderschap in niche"
            },
            {
                "blueprint_id": blueprint['id'],
                "type": "Content Marketing",
                "title": "Content Strategy Opportunity",
                "description": f"Content score van {scores.get('content', 50)}/100 biedt kansen voor thought leadership",
                "potential_value": "Brand awareness +30%"
            }
        ]
        
        for opp in opportunities:
            db.table("blueprint_opportunities").insert(opp).execute()
        
        threats = [
            {
                "blueprint_id": blueprint['id'],
                "severity": "high" if scores.get('seo', 50) < 50 else "medium",
                "title": "SEO Concurrentie" if scores.get('seo', 50) < 50 else "Markt Concurrentie",
                "description": "Concurrenten met betere SEO kunnen jouw potentiële klanten bereiken" if scores.get('seo', 50) < 50 else "Concurrenten investeren sterk in digitale marketing",
                "mitigation_strategy": "Implementeer SEO optimalisatie programma binnen 60 dagen" if scores.get('seo', 50) < 50 else "Focus on unique value proposition en niche marketing"
            }
        ]
        
        for threat in threats:
            db.table("blueprint_threats").insert(threat).execute()
        
        db.table("growth_blueprints").update({
            "status": "completed",
            "scan_progress": 100,
            "overall_score": real_data['overall_score'],
            "growth_reality_score": int(real_data['overall_score'] * 0.92),
            "scan_completed_at": datetime.utcnow().isoformat()
        }).eq("id", blueprint['id']).execute()
        
        print(f"✅ Blueprint {blueprint['id']} completed with REAL DATA!")
        print(f"   Overall Score: {real_data['overall_score']}/100")
        print(f"   Website: {scores['website']}/100")
        print(f"   SEO: {scores['seo']}/100")
        print(f"   Content: {scores['content']}/100")
        print(f"   Social: {scores['social']}/100")
        print(f"   Media: {scores['media']}/100")
        
    except Exception as e:
        print(f"❌ Error in real data analysis: {str(e)}")
        import traceback
        traceback.print_exc()
        
        db.table("growth_blueprints").update({
            "status": "failed",
            "scan_progress": 0
        }).eq("id", blueprint['id']).execute()
    
    finally:
        loop.close()


def generate_smart_recommendations(scores: dict, website_analysis: dict) -> list:
    """Generate smart recommendations based on actual scores"""
    
    recommendations = []
    
    if scores.get('seo', 50) < 70:
        recommendations.append({
            "priority": "critical" if scores.get('seo', 50) < 50 else "high",
            "category": "SEO",
            "title": "SEO Optimalisatie Prioriteit",
            "description": f"Je SEO score van {scores.get('seo', 50)}/100 beperkt je online vindbaarheid. Implementeer technische SEO fixes, optimaliseer meta tags en content voor relevante keywords.",
            "impact_score": 10 if scores.get('seo', 50) < 50 else 8,
            "effort_score": 6,
            "estimated_timeline_days": 60
        })
    
    if scores.get('content', 50) < 75:
        recommendations.append({
            "priority": "high",
            "category": "Content Marketing",
            "title": "Content Strategie Verbeteren",
            "description": f"Content score van {scores.get('content', 50)}/100 geeft ruimte voor verbetering. Start met regelmatige blog posts, case studies en thought leadership content.",
            "impact_score": 8,
            "effort_score": 5,
            "estimated_timeline_days": 90
        })
    
    if scores.get('social', 50) < 60:
        recommendations.append({
            "priority": "high",
            "category": "Social Media",
            "title": "Social Media Presence Uitbreiden",
            "description": f"Social score van {scores.get('social', 50)}/100 wijst op beperkte social media aanwezigheid. Focus op LinkedIn en één ander relevant platform.",
            "impact_score": 7,
            "effort_score": 4,
            "estimated_timeline_days": 45
        })
    
    if scores.get('website', 50) < 70:
        recommendations.append({
            "priority": "medium",
            "category": "Website",
            "title": "Website Optimalisatie",
            "description": f"Website score van {scores.get('website', 50)}/100 kan worden verbeterd. Focus op user experience, laadsnelheid en duidelijke call-to-actions.",
            "impact_score": 7,
            "effort_score": 6,
            "estimated_timeline_days": 60
        })
    
    recommendations.append({
        "priority": "medium",
        "category": "Strategy",
        "title": "Integrated Marketing Campaign",
        "description": "Lanceer een geïntegreerde marketing campagne die SEO, content en social media combineert voor maximale impact.",
        "impact_score": 9,
        "effort_score": 8,
        "estimated_timeline_days": 120
    })
    
    return recommendations[:5]


