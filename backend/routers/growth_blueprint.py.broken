    """Complete scan using MOCK DATA (for testing without API calls)"""
    
    import time
    
    try:
        print("🎭 Using mock data (set ENABLE_REAL_DATA=true for real analysis)")
        
        time.sleep(2)
        
        db.table("growth_blueprints").update({
            "scan_progress": 50,
            "status": "analyzing"
        }).eq("id", blueprint['id']).execute()
        
        time.sleep(2)
        
        status_quo_data = {
            "blueprint_id": blueprint['id'],
            "company_name": scan_input.company_name,
            "industry": scan_input.industry or "Technology",
            "website_url": scan_input.website_url,
            "website_score": 65,
            "seo_score": 45,
            "content_score": 78,
            "social_score": 82,
            "brand_consistency_score": 70,
            "market_position": 47,
            "market_position_percentile": 53,
            "strengths": [
                "Sterke social media engagement (82/100)",
                "Duidelijke waardepropositie",
                "Goede content kwaliteit (78/100)"
            ],
            "weaknesses": [
                "SEO prestaties hebben aandacht nodig (45/100)",
                "Website optimalisatie kansen"
            ],
            "current_limitations": [
                "Geen geautomatiseerde marketing workflows",
                "Handmatig lead qualification proces"
            ],
            "growth_accelerators": [
                "Content marketing strategie",
                "SEO optimalisatie programma",
                "Marketing automation platform"
            ]
        }
        db.table("blueprint_status_quo").insert(status_quo_data).execute()
        
        db.table("growth_blueprints").update({
            "status": "completed",
            "scan_progress": 100,
            "overall_score": 72,
            "growth_reality_score": 68,
            "scan_completed_at": datetime.utcnow().isoformat()
        }).eq("id", blueprint['id']).execute()
        
        print(f"✅ Blueprint {blueprint['id']} completed with MOCK DATA")
        
    except Exception as e:
        print(f"❌ Error: {str(e)}")
        import traceback
        traceback.print_exc()


@router.get("/{blueprint_id}")
def get_blueprint(
    blueprint_id: str,
    current_user: dict = Depends(get_current_user),
    db: Client = Depends(get_supabase_client)
):
    try:
        blueprint = db.table("growth_blueprints")\
            .select("*")\
            .eq("id", blueprint_id)\
            .single()\
            .execute()
        
        status_quo = db.table("blueprint_status_quo")\
            .select("*")\
            .eq("blueprint_id", blueprint_id)\
            .limit(1)\
            .execute()
        
        vision = db.table("blueprint_vision")\
            .select("*")\
            .eq("blueprint_id", blueprint_id)\
            .limit(1)\
            .execute()
        
        recommendations = db.table("blueprint_recommendations")\
            .select("*")\
            .eq("blueprint_id", blueprint_id)\
            .execute()
        
        opportunities = db.table("blueprint_opportunities")\
            .select("*")\
            .eq("blueprint_id", blueprint_id)\
            .execute()
        
        threats = db.table("blueprint_threats")\
            .select("*")\
            .eq("blueprint_id", blueprint_id)\
            .execute()
        
        return {
            "blueprint": blueprint.data,
            "status_quo": status_quo.data[0] if status_quo.data else None,
            "vision": vision.data[0] if vision.data else None,
            "budget_capacity": None,
            "endgame": None,
            "recommendations": recommendations.data,
            "opportunities": opportunities.data,
            "threats": threats.data
        }
    except Exception as e:
        print(f"Error: {e}")
        raise HTTPException(status_code=500, detail=str(e))
