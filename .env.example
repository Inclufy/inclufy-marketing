# Inclufy Marketing Platform - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: Supabase Configuration
# =============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# =============================================================================
# OPTIONAL: AI Service API Keys
# WARNING: These are exposed in the browser bundle. For production,
# move these to the backend and proxy AI requests through /api/ai/*
# =============================================================================
# VITE_OPENAI_API_KEY=sk-...
# VITE_ANTHROPIC_API_KEY=sk-ant-...
# VITE_STABILITY_API_KEY=sk-...
# VITE_REPLICATE_API_KEY=r8_...

# =============================================================================
# Backend Configuration (for backend/.env)
# =============================================================================
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-supabase-anon-key
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
