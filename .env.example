# Copy to .env and fill in your values
# These should match the web dashboard's Supabase project

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_API_URL=http://localhost:8000/api

# Pexels image search API key (https://www.pexels.com/api/)
EXPO_PUBLIC_PEXELS_KEY=your-pexels-api-key-here

# Sentry error reporting (optional)
# EXPO_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id
